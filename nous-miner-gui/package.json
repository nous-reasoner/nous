{
  "name": "nous-miner",
  "version": "1.1.0",
  "description": "NOUS Miner - Cogito Consensus mining client",
  "author": "NOUS <dev@nouschain.org>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "tiny-secp256k1": "^2.2.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "org.nouschain.miner",
    "productName": "NOUS Miner",
    "files": ["src/**/*", "public/**/*", "backend/miner", "backend/miner.exe"],
    "asarUnpack": ["backend/miner", "backend/miner.exe"],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
