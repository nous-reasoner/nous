{
  "name": "nous-miner",
  "version": "1.2.0",
  "description": "NOUS Reasoner - Cogito Consensus reasoning client",
  "author": "NOUS <dev@nouschain.org>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "org.nouschain.reasoner",
    "productName": "NOUS Reasoner",
    "files": ["src/**/*", "public/**/*", "backend/miner", "backend/miner.exe", "backend/miner-linux-amd64", "backend/wallet-backend", "backend/wallet-backend.exe", "backend/wallet-backend-linux-amd64"],
    "asarUnpack": ["backend/*"],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage"],
      "extraResources": [
        { "from": "backend/miner-linux-amd64", "to": "app.asar.unpacked/backend/miner" },
        { "from": "backend/wallet-backend-linux-amd64", "to": "app.asar.unpacked/backend/wallet-backend" }
      ]
    }
  }
}
